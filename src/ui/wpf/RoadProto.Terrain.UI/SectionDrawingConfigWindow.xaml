<Window x:Class="RoadProto.Terrain.UI.SectionDrawingConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="横断面图配置"
        Width="900"
        Height="580"
        MinWidth="760"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="Foreground" Value="#1F2933" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="配置文件" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Column="1"
                     Text="{Binding ConfigPath, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="2"
                    Content="导入"
                    Margin="8,0,0,0"
                    Click="OnImportClick" />
            <Button Grid.Column="3"
                    Content="导出"
                    Margin="8,0,0,0"
                    Click="OnExportClick" />
        </Grid>

        <TabControl Grid.Row="1">
            <TabItem Header="路面结构层">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,8">
                        <Button Content="新增" Width="72" Click="OnAddRowClick" />
                        <Button Content="删除" Width="72" Click="OnRemoveRowClick" />
                        <Button Content="上移" Width="72" Click="OnMoveUpClick" />
                        <Button Content="下移" Width="72" Margin="0" Click="OnMoveDownClick" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding PavementRows}"
                              SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="起点桩号" Binding="{Binding StartStation}" Width="120" />
                            <DataGridTextColumn Header="终点桩号" Binding="{Binding EndStation}" Width="120" />
                            <DataGridTemplateColumn Header="路基类型" Width="280">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding ComponentDisplayText}"
                                                HorizontalContentAlignment="Left"
                                                Margin="0"
                                                Click="OnComponentTypesClick" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="模板" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <DockPanel LastChildFill="True">
                                            <Button DockPanel.Dock="Right"
                                                    Content="选择"
                                                    Margin="8,0,0,0"
                                                    Padding="10,2"
                                                    Click="OnPickTemplateClick" />
                                            <TextBlock Text="{Binding TemplateName}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="清表">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,8">
                        <Button Content="新增" Width="72" Click="OnAddClearTableRowClick" />
                        <Button Content="删除" Width="72" Click="OnRemoveClearTableRowClick" />
                        <Button Content="上移" Width="72" Click="OnMoveClearTableRowUpClick" />
                        <Button Content="下移" Width="72" Margin="0" Click="OnMoveClearTableRowDownClick" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ClearTableRows}"
                              SelectedItem="{Binding SelectedClearTableRow, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="起点桩号" Binding="{Binding StartStation}" Width="110" />
                            <DataGridTextColumn Header="终点桩号" Binding="{Binding EndStation}" Width="110" />
                            <DataGridTextColumn Header="左侧坡率" Binding="{Binding LeftSlopeRatio}" Width="110" />
                            <DataGridTextColumn Header="右侧坡率" Binding="{Binding RightSlopeRatio}" Width="110" />
                            <DataGridTextColumn Header="厚度" Binding="{Binding Thickness}" Width="90" />
                            <DataGridTemplateColumn Header="作用范围" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.ClearTableScopeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding Scope, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="挖方是否清表" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.ClearTableCutOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding ClearCut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="ErrorTextBlock"
                       Foreground="#B42318"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="绘制" Width="90" Click="OnDrawClick" />
                <Button Content="取消" Width="90" Margin="0" Click="OnCancelClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>

<Window x:Class="RoadProto.Terrain.UI.AlignmentCenterlineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="道路中线"
        Width="680"
        Height="620"
        MinWidth="620"
        MinHeight="540"
        WindowStartupLocation="CenterScreen"
        Background="#F3F5F7">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="BorderBrush" Value="#D8DEE6" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="Foreground" Value="#1F2933" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="30" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="道路中线" FontSize="24" FontWeight="SemiBold" />
            <TextBlock x:Name="SubtitleText" Text="编辑道路属性和平曲线参数" Margin="0,5,0,0" Foreground="#5D6875" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <TabControl x:Name="EditorTabs">
                <TabItem x:Name="PropertiesTab" Header="道路属性">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,14,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="道路名称" VerticalAlignment="Center" Margin="0,0,12,12" />
                            <TextBox x:Name="RoadNameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,12" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="道路等级" VerticalAlignment="Center" Margin="0,0,12,12" />
                            <ComboBox x:Name="RoadGradeComboBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,12" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="关联数模" VerticalAlignment="Center" Margin="0,0,12,12" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                                <CheckBox x:Name="LinkedTerrainCheckBox" Content="启用关联" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <TextBox x:Name="LinkedTerrainHandleTextBox" Width="220" Margin="0,0,10,0" />
                                <Button Content="选择" Click="SelectTerrainButton_Click" Margin="0" />
                            </StackPanel>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="桩号标注" VerticalAlignment="Center" Margin="0,0,12,12" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBox x:Name="StationIntervalTextBox" Width="120" IsReadOnly="True" Margin="0,0,10,0" />
                                <Button Content="设置" Click="StationSettingsButton_Click" Margin="0" />
                            </StackPanel>

                            <TextBlock Grid.Row="4" Grid.Column="1"
                                       Text="桩号标注会按间距重建，并在图中以引线标注形式显示。"
                                       Foreground="#5D6875"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="CurveTab" Header="平曲线参数">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,14,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="当前曲线序号" VerticalAlignment="Center" Margin="0,0,12,12" />
                            <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="PreviousCurveButton" Grid.Column="0" Content="&lt;" Click="PreviousCurveButton_Click" Margin="0,0,8,0" MinWidth="42" />
                                <TextBlock x:Name="CurveTitleTextBlock" Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <Button x:Name="NextCurveButton" Grid.Column="2" Content="&gt;" Click="NextCurveButton_Click" Margin="8,0,0,0" MinWidth="42" />
                            </Grid>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="前切线长 T1" VerticalAlignment="Center" Margin="0,0,12,12" />
                            <TextBox x:Name="TangentInTextBox" Grid.Row="1" Grid.Column="1" IsReadOnly="True" Margin="0,0,0,12" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="后切线长 T2" VerticalAlignment="Center" Margin="0,0,12,12" />
                            <TextBox x:Name="TangentOutTextBox" Grid.Row="2" Grid.Column="1" IsReadOnly="True" Margin="0,0,0,12" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="第一缓和曲线长 LS1" VerticalAlignment="Center" Margin="0,0,12,12" />
                            <TextBox x:Name="Ls1TextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,12" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="圆曲线半径 R" VerticalAlignment="Center" Margin="0,0,12,12" />
                            <TextBox x:Name="RadiusTextBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,12" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="第二缓和曲线长 LS2" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBox x:Name="Ls2TextBox" Grid.Row="5" Grid.Column="1" />
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ErrorTextBlock" Foreground="#B42318" TextWrapping="Wrap" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="确定" Click="OkButton_Click" />
                    <Button Content="取消" Click="CancelButton_Click" Margin="0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

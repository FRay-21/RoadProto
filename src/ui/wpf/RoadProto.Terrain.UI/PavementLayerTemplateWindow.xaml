<Window x:Class="RoadProto.Terrain.UI.PavementLayerTemplateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="路面结构层模板"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="390" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.ColumnSpan="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="76" />
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="96" />
                <ColumnDefinition Width="92" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="模板名称" VerticalAlignment="Center" />
            <TextBox x:Name="TemplateNameBox" Grid.Column="1" Height="28" TextChanged="GlobalInput_Changed" />
            <TextBlock Grid.Column="2" Text="显示比例" VerticalAlignment="Center" Margin="14,0,0,0" />
            <TextBox x:Name="DisplayScaleBox" Grid.Column="3" Height="28" TextChanged="GlobalInput_Changed" />
            <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ImportXmlButton" Content="导入 XML" Width="92" Height="28" Margin="0,0,8,0" Click="ImportXml_Click" />
                <Button x:Name="SaveXmlButton" Content="保存 XML" Width="92" Height="28" Click="SaveXml_Click" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Grid.Column="0"
                BorderBrush="#56606D"
                BorderThickness="1"
                Background="#151A20"
                ClipToBounds="True">
            <Canvas x:Name="PreviewCanvas"
                    Background="#151A20"
                    ClipToBounds="True"
                    SizeChanged="PreviewCanvas_SizeChanged"
                    MouseWheel="PreviewCanvas_MouseWheel"
                    MouseLeftButtonDown="PreviewCanvas_MouseLeftButtonDown"
                    MouseDown="PreviewCanvas_MouseMiddleButtonDown"
                    MouseUp="PreviewCanvas_MouseMiddleButtonUp"
                    MouseMove="PreviewCanvas_MouseMove" />
        </Border>

        <ScrollViewer Grid.Row="1"
                      Grid.Column="1"
                      Margin="12,0,0,0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="通用参数" FontWeight="SemiBold" Margin="0,0,0,8" />
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="116" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="预览宽度" VerticalAlignment="Center" />
                    <TextBox x:Name="PreviewWidthBox" Grid.Column="1" Height="26" TextChanged="GlobalInput_Changed" />
                    <TextBlock Grid.Row="1" Text="结构层数量" VerticalAlignment="Center" />
                    <TextBox x:Name="LayerCountBox" Grid.Row="1" Grid.Column="1" Height="26" TextChanged="LayerCountBox_TextChanged" />
                    <TextBlock Grid.Row="2" Text="显示方式" VerticalAlignment="Center" />
                    <ComboBox x:Name="DisplayModeBox" Grid.Row="2" Grid.Column="1" Height="26" SelectionChanged="GlobalInput_Changed" />
                    <TextBlock Grid.Row="3" Text="当前编辑层" VerticalAlignment="Center" />
                    <DockPanel Grid.Row="3" Grid.Column="1" LastChildFill="True">
                        <Button x:Name="PreviousLayerButton"
                                DockPanel.Dock="Left"
                                Content="▲"
                                Width="30"
                                Height="26"
                                Margin="0,0,4,0"
                                ToolTip="编辑上一层"
                                Click="PreviousLayerButton_Click" />
                        <Button x:Name="NextLayerButton"
                                DockPanel.Dock="Right"
                                Content="▼"
                                Width="30"
                                Height="26"
                                Margin="4,0,0,0"
                                ToolTip="编辑下一层"
                                Click="NextLayerButton_Click" />
                        <TextBox x:Name="CurrentLayerBox" Height="26" TextChanged="CurrentLayerBox_TextChanged" />
                    </DockPanel>
                </Grid>
                <StackPanel x:Name="LayersPanel" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="确定" Width="90" Height="32" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click" />
            <Button Content="取消" Width="90" Height="32" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click" />
            <Button Content="应用" Width="90" Height="32" Click="Apply_Click" />
        </StackPanel>
    </Grid>
</Window>

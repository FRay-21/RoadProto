<UserControl x:Class="RoadProto.Terrain.UI.AgentAssistantControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="340"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#151A21" />
        <SolidColorBrush x:Key="HeaderBorderBrush" Color="#2C3440" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F4F7FB" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A7B0BF" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#202733" />
        <SolidColorBrush x:Key="UserMessageBrush" Color="#223B55" />
        <SolidColorBrush x:Key="AgentMessageBrush" Color="#242B36" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4FB6FF" />
        <Style x:Key="ActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Foreground" Value="#F8FBFF" />
            <Setter Property="Background" Value="#2F80ED" />
            <Setter Property="BorderBrush" Value="#55A8FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Foreground" Value="#D6DEEA" />
            <Setter Property="Background" Value="#2B3340" />
            <Setter Property="BorderBrush" Value="#445164" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PanelBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="14,12" BorderBrush="{StaticResource HeaderBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="RoadProto Agent"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="StatusText"
                           Grid.Row="1"
                           Text="连接本地 Agent 后端中"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           FontSize="12"
                           Margin="0,4,0,0" />
            </Grid>
        </Border>

        <ScrollViewer x:Name="MessageScrollViewer"
                      Grid.Row="1"
                      Padding="14"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="MessagePanel" />
        </ScrollViewer>

        <Border Grid.Row="2" Padding="12" BorderBrush="{StaticResource HeaderBorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InputBox"
                         MinHeight="44"
                         MaxHeight="112"
                         Padding="10,8"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         InputMethod.IsInputMethodEnabled="True"
                         PreviewKeyDown="InputBox_PreviewKeyDown"
                         VerticalScrollBarVisibility="Auto"
                         Foreground="{StaticResource PrimaryTextBrush}"
                         Background="#10141A"
                         BorderBrush="#3B4656"
                         BorderThickness="1" />
                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="发送"
                        Width="72"
                        Margin="8,0,0,0"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="SendButton_Click" />
            </Grid>
        </Border>
    </Grid>
</UserControl>

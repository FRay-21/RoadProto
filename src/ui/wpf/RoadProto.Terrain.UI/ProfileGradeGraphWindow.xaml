<Window x:Class="RoadProto.Terrain.UI.ProfileGradeGraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="纵断面拉坡图"
        Width="560"
        Height="520"
        MinWidth="520"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="#F3F5F7">
    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="BorderBrush" Value="#D8DEE6" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="Foreground" Value="#1F2933" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="30" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="纵断面拉坡图" FontSize="24" FontWeight="SemiBold" />
            <TextBlock x:Name="SourceTextBlock" Margin="0,5,0,0" Foreground="#5D6875" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="145" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="图名" VerticalAlignment="Center" Margin="0,0,12,12" />
                    <TextBox x:Name="GraphNameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="地面线颜色" VerticalAlignment="Center" Margin="0,0,12,12" />
                    <ComboBox x:Name="GroundLineColorComboBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Index"
                              Margin="0,0,0,12" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="地面线宽度" VerticalAlignment="Center" Margin="0,0,12,12" />
                    <TextBox x:Name="GroundLineWidthTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="地面线精度" VerticalAlignment="Center" Margin="0,0,12,12" />
                    <TextBox x:Name="GroundLinePrecisionTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="纵向比例" VerticalAlignment="Center" Margin="0,0,12,12" />
                    <ComboBox x:Name="VerticalScaleComboBox"
                              Grid.Row="4"
                              Grid.Column="1"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Value"
                              Margin="0,0,0,12" />

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="网格线间距" VerticalAlignment="Center" Margin="0,0,12,12" />
                    <TextBox x:Name="GridSpacingTextBox" Grid.Row="5" Grid.Column="1" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="样本数量" VerticalAlignment="Center" Margin="0,0,12,12" />
                    <TextBox x:Name="SampleCountTextBox" Grid.Row="6" Grid.Column="1" IsReadOnly="True" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="道路中线" VerticalAlignment="Center" Margin="0,0,12,12" />
                    <TextBox x:Name="RoadCenterlineHandleTextBox" Grid.Row="7" Grid.Column="1" IsReadOnly="True" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="地形数模" VerticalAlignment="Center" Margin="0,0,12,12" />
                    <TextBox x:Name="TerrainTinHandleTextBox" Grid.Row="8" Grid.Column="1" IsReadOnly="True" Margin="0,0,0,12" />

                    <TextBlock Grid.Row="9" Grid.Column="0" Text="DMX 文件" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <TextBox x:Name="DmxFilePathTextBox" Grid.Row="9" Grid.Column="1" IsReadOnly="True" />
                </Grid>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ErrorTextBlock" Foreground="#B42318" TextWrapping="Wrap" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="UpdateGroundLineButton" Content="更新地面线" Click="UpdateGroundLineButton_Click" />
                    <Button Content="确定" Click="OkButton_Click" />
                    <Button Content="取消" Click="CancelButton_Click" Margin="0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

<Window x:Class="RoadProto.Terrain.UI.StationLabelSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="桩号标注设置"
        Width="360"
        Height="190"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F3F5F7">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="Foreground" Value="#1F2933" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="桩号标注间距" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBox x:Name="IntervalTextBox" />
            <TextBlock x:Name="ErrorTextBlock" Foreground="#B42318" TextWrapping="Wrap" Margin="0,8,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" Click="OkButton_Click" />
            <Button Content="取消" Click="CancelButton_Click" Margin="0" />
        </StackPanel>
    </Grid>
</Window>

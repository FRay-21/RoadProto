<Window x:Class="RoadProto.Terrain.UI.SubgradeTemplateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="路基模板"
        Width="1120"
        Height="720"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.ColumnSpan="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="模板名称" VerticalAlignment="Center" />
            <TextBox x:Name="TemplateNameBox" Grid.Column="1" Height="28" TextChanged="GlobalInput_Changed" />
            <TextBlock Grid.Column="2" Text="显示比例" VerticalAlignment="Center" Margin="12,0,0,0" />
            <ComboBox x:Name="DisplayScaleComboBox" Grid.Column="3" Height="28" SelectionChanged="GlobalInput_Changed" />
            <TextBlock Grid.Column="4" Text="道路等级" VerticalAlignment="Center" Margin="12,0,0,0" />
            <ComboBox x:Name="RoadGradeComboBox" Grid.Column="5" Height="28" SelectionChanged="RoadGradeComboBox_SelectionChanged" />
        </Grid>

        <Border Grid.Row="1" Grid.Column="0" BorderBrush="#B8C0CC" BorderThickness="1" Background="#FFFFFF" ClipToBounds="True">
            <Canvas x:Name="PreviewCanvas" Background="#FAFBFC" ClipToBounds="True" SizeChanged="PreviewCanvas_SizeChanged" />
        </Border>

        <ScrollViewer Grid.Row="1" Grid.Column="1" Margin="12,0,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="64" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="部件" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="左" Width="56" Click="PreviousComponent_Click" />
                    <Button Grid.Column="2" Content="右" Width="56" Click="NextComponent_Click" />
                </Grid>

                <ListBox x:Name="ComponentListBox"
                         Height="130"
                         DisplayMemberPath="DisplayName"
                         SelectionChanged="ComponentListBox_SelectionChanged" />

                <Grid Margin="0,10,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="AddSideComboBox" Height="28" />
                    <ComboBox x:Name="AddTypeComboBox" Grid.Column="1" Height="28" Margin="8,0" />
                    <Button Grid.Column="2" Content="新增部件" Click="AddComponent_Click" />
                </Grid>

                <Button Content="删除选中部件" Height="30" Margin="0,0,0,12" Click="DeleteComponent_Click" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="98" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="34" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="侧别" VerticalAlignment="Center" />
                    <TextBlock x:Name="SelectedSideText" Grid.Column="1" VerticalAlignment="Center" />

                    <TextBlock Grid.Row="1" Text="类型" VerticalAlignment="Center" />
                    <ComboBox x:Name="ComponentTypeComboBox" Grid.Row="1" Grid.Column="1" Height="28" SelectionChanged="ComponentInput_Changed" />

                    <TextBlock Grid.Row="2" Text="宽度" VerticalAlignment="Center" />
                    <TextBox x:Name="WidthBox" Grid.Row="2" Grid.Column="1" Height="26" TextChanged="ComponentInput_Changed" />

                    <TextBlock Grid.Row="3" Text="高度差" VerticalAlignment="Center" />
                    <TextBox x:Name="HeightBox" Grid.Row="3" Grid.Column="1" Height="26" TextChanged="ComponentInput_Changed" />

                    <TextBlock Grid.Row="4" Text="坡度方式" VerticalAlignment="Center" />
                    <ComboBox x:Name="SlopeModeComboBox" Grid.Row="4" Grid.Column="1" Height="28" SelectionChanged="ComponentInput_Changed" />

                    <TextBlock Grid.Row="5" Text="固定坡度" VerticalAlignment="Center" />
                    <TextBox x:Name="FixedSlopeBox" Grid.Row="5" Grid.Column="1" Height="26" TextChanged="ComponentInput_Changed" />

                    <TextBlock Grid.Row="6" Text="颜色 RGB" VerticalAlignment="Center" />
                    <Grid Grid.Row="6" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="34" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ColorRBox" Height="26" TextChanged="ComponentInput_Changed" />
                        <TextBox x:Name="ColorGBox" Grid.Column="1" Height="26" Margin="4,0" TextChanged="ComponentInput_Changed" />
                        <TextBox x:Name="ColorBBox" Grid.Column="2" Height="26" TextChanged="ComponentInput_Changed" />
                        <Border x:Name="ColorPreviewBorder" Grid.Column="3" Height="24" Margin="6,1,0,1" BorderBrush="#888" BorderThickness="1" />
                    </Grid>

                    <Button Grid.Row="7" Grid.ColumnSpan="2" Content="变宽数据表" Height="28" Click="WideningTable_Click" />
                    <Button Grid.Row="8" Grid.ColumnSpan="2" Content="坡度变化数据表" Height="28" Click="SlopeTable_Click" />

                    <CheckBox x:Name="PavementLayerCheckBox"
                              Grid.Row="9"
                              Grid.ColumnSpan="2"
                              Content="启用路面结构层模板"
                              VerticalAlignment="Center"
                              Focusable="False"
                              IsHitTestVisible="False"
                              Checked="PavementLayerCheckBox_Changed"
                              Unchecked="PavementLayerCheckBox_Changed" />

                    <TextBlock Grid.Row="10" Text="模板名称" VerticalAlignment="Center" />
                    <TextBox x:Name="PavementLayerNameBox" Grid.Row="10" Grid.Column="1" Height="26" IsReadOnly="True" />

                    <TextBlock Grid.Row="11" Text="模板 handle" VerticalAlignment="Center" />
                    <TextBox x:Name="PavementLayerHandleBox" Grid.Row="11" Grid.Column="1" Height="26" IsReadOnly="True" />

                    <Button x:Name="PickPavementLayerTemplateButton" Grid.Row="12" Grid.ColumnSpan="2" Content="选择结构层模板" Height="28" Click="PickPavementLayerTemplate_Click" />
                    <Button x:Name="ClearPavementLayerTemplateButton" Grid.Row="13" Grid.ColumnSpan="2" Content="清除结构层模板" Height="28" Click="ClearPavementLayerTemplate_Click" />
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Width="90" Height="32" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click" />
            <Button Content="取消" Width="90" Height="32" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="RoadProto.Terrain.UI.StationValueTableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="数据表"
        Width="420"
        Height="420"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="新增" Width="72" Margin="0,0,8,0" Click="Add_Click" />
            <Button Content="删除" Width="72" Margin="0,0,16,0" Click="Delete_Click" />
            <Button Content="确定" Width="80" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click" />
            <Button Content="取消" Width="80" IsCancel="True" />
        </StackPanel>
        <DataGrid x:Name="RowsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="True"
                  CanUserDeleteRows="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Extended">
            <DataGrid.Columns>
                <DataGridTextColumn Header="桩号" Binding="{Binding Station}" Width="*" />
                <DataGridTextColumn x:Name="ValueColumn" Header="值" Binding="{Binding Value}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>

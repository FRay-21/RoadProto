<Window x:Class="RoadProto.Terrain.UI.RoadModelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:bridge="clr-namespace:RoadProto.Terrain.UI.Bridge"
        Title="横断面戴帽"
        Width="980"
        Height="640"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#F3F5F7">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="Foreground" Value="#1F2933" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="横断面戴帽"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <TabControl Grid.Row="1">
            <TabItem Header="路基模板">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="采样间隔" VerticalAlignment="Center" />
                        <TextBox x:Name="SampleIntervalTextBox"
                                 Grid.Column="1"
                                 Text="{Binding SampleIntervalText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="3" Text="道路中线 handle" VerticalAlignment="Center" />
                        <TextBox x:Name="RoadCenterlineHandleTextBox"
                                 Grid.Column="4"
                                 IsReadOnly="True"
                                 Text="{Binding RoadCenterlineHandle, Mode=OneWay}" />
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="新增" Click="OnAddAssignment" />
                        <Button Content="删除" Click="OnDeleteAssignment" />
                        <Button Content="上移" Click="OnMoveAssignmentUp" />
                        <Button Content="下移" Click="OnMoveAssignmentDown" />
                        <Button Content="点选模板" Click="OnPickTemplate" />
                    </StackPanel>

                    <DataGrid Grid.Row="2"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              ItemsSource="{Binding Assignments}"
                              SelectedItem="{Binding SelectedAssignment, Mode=TwoWay}"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="起点桩号" Binding="{Binding StartStation}" Width="*" />
                            <DataGridTextColumn Header="终点桩号" Binding="{Binding EndStation}" Width="*" />
                            <DataGridTextColumn Header="路基模板 handle" Binding="{Binding TemplateHandle}" Width="1.4*" />
                            <DataGridTextColumn Header="路基模板名称" Binding="{Binding TemplateName}" Width="1.6*" />
                            <DataGridTemplateColumn Header="点选模板" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="点选"
                                                Margin="0"
                                                Padding="8,3"
                                                Click="OnPickTemplate" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="边坡模板">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="左侧搜索宽度" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding LeftSlopeSearchWidthText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="3" Text="右侧搜索宽度" VerticalAlignment="Center" />
                        <TextBox Grid.Column="4" Text="{Binding RightSlopeSearchWidthText, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <TabControl Grid.Row="1">
                        <TabItem Header="左侧边坡模板">
                            <Grid Margin="0,12,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="新增组" Click="OnAddLeftSlopeGroup" />
                                    <Button Content="删除组" Click="OnDeleteLeftSlopeGroup" />
                                    <Button Content="上移" Click="OnMoveLeftSlopeGroupUp" />
                                    <Button Content="下移" Click="OnMoveLeftSlopeGroupDown" />
                                    <Button Content="点选模板" Click="OnPickLeftSlopeTemplate" />
                                    <Button Content="清空组内模板" Click="OnClearLeftSlopeTemplates" />
                                </StackPanel>
                                <DataGrid Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          ItemsSource="{Binding LeftSlopeGroups}"
                                          SelectedItem="{Binding SelectedLeftSlopeGroup, Mode=TwoWay}"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="起点桩号" Binding="{Binding StartStation}" Width="*" />
                                        <DataGridTextColumn Header="终点桩号" Binding="{Binding EndStation}" Width="*" />
                                        <DataGridTextColumn Header="组内模板顺序" Binding="{Binding TemplateSummary}" IsReadOnly="True" Width="2.4*" />
                                        <DataGridTemplateColumn Header="管理模板组" Width="120">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="管理模板组" Click="OnManageLeftSlopeGroup" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <GroupBox Grid.Row="2" Header="当前模板组管理" Margin="0,12,0,0">
                                    <Grid Margin="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button Content="点选边坡模板" Click="OnPickLeftSlopeTemplate" />
                                            <Button Content="删除组内模板" Click="OnDeleteLeftSlopeTemplate" />
                                            <Button Content="组内模板上移" Click="OnMoveLeftSlopeTemplateUp" />
                                            <Button Content="组内模板下移" Click="OnMoveLeftSlopeTemplateDown" />
                                            <Button Content="清空组内模板" Click="OnClearLeftSlopeTemplates" />
                                        </StackPanel>
                                        <DataGrid Grid.Row="1"
                                                  Height="120"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  ItemsSource="{Binding SelectedLeftSlopeGroup.Templates}"
                                                  SelectedItem="{Binding SelectedLeftSlopeTemplate, Mode=TwoWay}"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="Horizontal">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="模板 handle" Binding="{Binding TemplateHandle}" IsReadOnly="True" Width="*" />
                                                <DataGridTextColumn Header="模板名称" Binding="{Binding TemplateName}" IsReadOnly="True" Width="2*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </GroupBox>
                            </Grid>
                        </TabItem>
                        <TabItem Header="右侧边坡模板">
                            <Grid Margin="0,12,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="新增组" Click="OnAddRightSlopeGroup" />
                                    <Button Content="删除组" Click="OnDeleteRightSlopeGroup" />
                                    <Button Content="上移" Click="OnMoveRightSlopeGroupUp" />
                                    <Button Content="下移" Click="OnMoveRightSlopeGroupDown" />
                                    <Button Content="点选模板" Click="OnPickRightSlopeTemplate" />
                                    <Button Content="清空组内模板" Click="OnClearRightSlopeTemplates" />
                                </StackPanel>
                                <DataGrid Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          ItemsSource="{Binding RightSlopeGroups}"
                                          SelectedItem="{Binding SelectedRightSlopeGroup, Mode=TwoWay}"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="起点桩号" Binding="{Binding StartStation}" Width="*" />
                                        <DataGridTextColumn Header="终点桩号" Binding="{Binding EndStation}" Width="*" />
                                        <DataGridTextColumn Header="组内模板顺序" Binding="{Binding TemplateSummary}" IsReadOnly="True" Width="2.4*" />
                                        <DataGridTemplateColumn Header="管理模板组" Width="120">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="管理模板组" Click="OnManageRightSlopeGroup" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <GroupBox Grid.Row="2" Header="当前模板组管理" Margin="0,12,0,0">
                                    <Grid Margin="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button Content="点选边坡模板" Click="OnPickRightSlopeTemplate" />
                                            <Button Content="删除组内模板" Click="OnDeleteRightSlopeTemplate" />
                                            <Button Content="组内模板上移" Click="OnMoveRightSlopeTemplateUp" />
                                            <Button Content="组内模板下移" Click="OnMoveRightSlopeTemplateDown" />
                                            <Button Content="清空组内模板" Click="OnClearRightSlopeTemplates" />
                                        </StackPanel>
                                        <DataGrid Grid.Row="1"
                                                  Height="120"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  ItemsSource="{Binding SelectedRightSlopeGroup.Templates}"
                                                  SelectedItem="{Binding SelectedRightSlopeTemplate, Mode=TwoWay}"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="Horizontal">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="模板 handle" Binding="{Binding TemplateHandle}" IsReadOnly="True" Width="*" />
                                                <DataGridTextColumn Header="模板名称" Binding="{Binding TemplateName}" IsReadOnly="True" Width="2*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </GroupBox>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>

            <TabItem Header="构造物">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="新增" Click="OnAddStructure" />
                        <Button Content="删除" Click="OnDeleteStructure" />
                        <Button Content="上移" Click="OnMoveStructureUp" />
                        <Button Content="下移" Click="OnMoveStructureDown" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              ItemsSource="{Binding Structures}"
                              SelectedItem="{Binding SelectedStructure, Mode=TwoWay}"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="起点桩号" Binding="{Binding StartStation}" Width="*" />
                            <DataGridTextColumn Header="终点桩号" Binding="{Binding EndStation}" Width="*" />
                            <DataGridComboBoxColumn Header="构造物类型"
                                                    ItemsSource="{x:Static bridge:RoadModelStructureOptions.Types}"
                                                    DisplayMemberPath="Label"
                                                    SelectedValuePath="Value"
                                                    SelectedValueBinding="{Binding Type}"
                                                    Width="*" />
                            <DataGridComboBoxColumn Header="范围"
                                                    ItemsSource="{x:Static bridge:RoadModelStructureOptions.SideRanges}"
                                                    DisplayMemberPath="Label"
                                                    SelectedValuePath="Value"
                                                    SelectedValueBinding="{Binding SideRange}"
                                                    Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="ErrorTextBlock"
                       Foreground="#B42318"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="生成模型" Click="OnGenerateModel" />
                <Button Content="取消" Click="OnCancel" Margin="0" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>

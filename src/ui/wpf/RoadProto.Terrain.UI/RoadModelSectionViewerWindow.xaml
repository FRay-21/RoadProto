<Window x:Class="RoadProto.Terrain.UI.RoadModelSectionViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="查看横断面"
        Width="980"
        Height="660"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="Foreground" Value="#1F2933" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="14,5" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="查看横断面" FontSize="24" FontWeight="SemiBold" />
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="道路模型 handle：" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Handle}" Margin="0,0,22,0" />
                <TextBlock Text="道路中线 handle：" FontWeight="SemiBold" />
                <TextBlock Text="{Binding RoadCenterlineHandle}" Margin="0,0,22,0" />
                <TextBlock Text="桩号数量：" FontWeight="SemiBold" />
                <TextBlock Text="{Binding PreviewCount}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D7DEE8"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="桩号"
                               FontWeight="SemiBold"
                               Margin="12,10,12,8" />
                    <ListBox x:Name="StationListBox"
                             ItemsSource="{Binding Previews}"
                             SelectedItem="{Binding SelectedPreview, Mode=TwoWay}"
                             DisplayMemberPath="DisplayStation"
                             BorderThickness="0" />
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D7DEE8"
                    BorderThickness="1">
                <Grid>
                    <Canvas x:Name="PreviewCanvas"
                            Background="#FFFFFF"
                            ClipToBounds="True"
                            Focusable="True"
                            SizeChanged="OnPreviewCanvasSizeChanged"
                            MouseWheel="PreviewCanvas_MouseWheel"
                            MouseLeftButtonDown="PreviewCanvas_MouseLeftButtonDown"
                            MouseLeftButtonUp="PreviewCanvas_MouseLeftButtonUp"
                            MouseMove="PreviewCanvas_MouseMove"
                            MouseLeave="PreviewCanvas_MouseLeave" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Rectangle Width="22" Height="3" Fill="#1C73DC" VerticalAlignment="Center" />
                            <TextBlock Text="路基模板" Margin="6,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Rectangle Width="22" Height="3" Fill="#2A9D5B" VerticalAlignment="Center" />
                            <TextBlock Text="边坡模板" Margin="6,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Rectangle Width="22" Height="3" Fill="#846038" VerticalAlignment="Center" />
                            <TextBlock Text="地面线" Margin="6,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="22" Height="3" Fill="#C4561C" VerticalAlignment="Center" />
                            <TextBlock Text="结构层" Margin="6,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="绘制横断面" Margin="0,0,8,0" Click="OnDrawSections" />
                <Button Content="关闭" Click="OnClose" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
